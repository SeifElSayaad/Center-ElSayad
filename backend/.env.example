# Database Configuration
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME

# JWT Authentication
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d

# Server Configuration
PORT=3000
NODE_ENV=development

# CORS Origins (comma separated)
CORS_ORIGINS=http://localhost:8081,http://localhost:19000,http://localhost:5173

# Email (Transactional — for password reset OTPs)
# Sign up at https://resend.com for a free API key
EMAIL_PROVIDER=resend
EMAIL_API_KEY=re_your_api_key_here
EMAIL_FROM=noreply@your-domain.com

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# B2B Discount Percentage
B2B_DISCOUNT_PERCENT=20
