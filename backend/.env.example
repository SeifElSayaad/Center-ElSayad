# ─── Database ────────────────────────────────────────────────────────────────\n# Local dev: use localhost; Docker: use service name (e.g. database)\nDATABASE_URL=postgresql://elsayad:your_password_here@localhost:5432/ecommerce\n\n# ─── JWT Authentication ───────────────────────────────────────────────────────\n# IMPORTANT: Generate a strong random secret for production:\n#   openssl rand -hex 64\nJWT_SECRET=your-super-secret-jwt-key-change-this-in-production\nJWT_EXPIRES_IN=7d\n\n# ─── Server ───────────────────────────────────────────────────────────────────\nPORT=3000\nNODE_ENV=development\n\n# ─── CORS ────────────────────────────────────────────────────────────────────\n# Comma-separated list of allowed origins\n# Development: mobile dev server + admin dev server\n# Production: your deployed admin panel URL\nCORS_ORIGINS=http://localhost:8081,http://localhost:19000,http://localhost:5173\n\n# ─── Email (Transactional) ────────────────────────────────────────────────────\n# Provider: resend (recommended — free tier at https://resend.com)\nEMAIL_PROVIDER=resend\nEMAIL_API_KEY=re_your_api_key_here\nEMAIL_FROM=onboarding@resend.dev\n# In production, use your verified domain:\n# EMAIL_FROM=noreply@yourdomain.com\n\n# ─── File Upload ──────────────────────────────────────────────────────────────\nMAX_FILE_SIZE=5242880\nUPLOAD_DIR=./uploads\n\n# ─── Cloudinary (Image Uploads) ───────────────────────────────────────────────\n# Create a free account at https://cloudinary.com\n# If left empty, uploads will return placeholder images (dev only)\nCLOUDINARY_CLOUD_NAME=\nCLOUDINARY_API_KEY=\nCLOUDINARY_API_SECRET=\n\n# ─── B2B Pricing ─────────────────────────────────────────────────────────────\n# Discount percentage applied to all B2B users\nB2B_DISCOUNT_PERCENT=20\n
