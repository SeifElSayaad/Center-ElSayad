// Center-ElSayad E-Commerce - Prisma Schema
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserType {
  B2C // Individual customer
  ADMIN
}

enum Gender {
  MALE
  FEMALE
}

enum AdminRole {
  SUPER_ADMIN // Full access
  INVENTORY_MANAGER // Products & categories only
  ORDER_MANAGER // Orders & customer support
  CUSTOMER_SERVICE // View-only + order status updates
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  CASH_ON_DELIVERY
  MOCK_PAYMENT
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  authProvider String? // 'google' | 'facebook' | null (email)
  firstName    String
  lastName     String
  phone        String?
  gender       Gender?
  avatarUrl    String?
  userType     UserType @default(B2C)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Admin-specific fields (null for B2C)
  adminProfile AdminProfile?

  // Relations
  addresses        Address[]       @relation("UserAddresses")
  defaultAddress   Address?        @relation("DefaultAddress", fields: [defaultAddressId], references: [id])
  defaultAddressId String?
  orders           Order[]
  cartItems        CartItem[]
  reviews          Review[]
  passwordResets   PasswordReset[]
  favorites        Favorite[]

  @@map("users")
}

// ─────────────────────────────────────────────
// ADMIN PROFILE
// ─────────────────────────────────────────────

model AdminProfile {
  id        String    @id @default(cuid())
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      AdminRole @default(CUSTOMER_SERVICE)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("admin_profiles")
}

// ─────────────────────────────────────────────
// ADDRESS
// ─────────────────────────────────────────────

model Address {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation("UserAddresses", fields: [userId], references: [id], onDelete: Cascade)
  defaultForUsers User[]   @relation("DefaultAddress")
  label           String? // e.g. "Home", "Office"
  fullName        String
  phone           String
  street          String
  city            String
  state           String?
  country         String   @default("Egypt")
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  orders Order[]

  @@map("addresses")
}

// ─────────────────────────────────────────────
// CATEGORY
// ─────────────────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  imageUrl    String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@map("categories")
}

// ─────────────────────────────────────────────
// PRODUCT
// ─────────────────────────────────────────────

model Product {
  id            String   @id @default(cuid())
  categoryId    String
  category      Category @relation(fields: [categoryId], references: [id])
  name          String
  slug          String   @unique
  description   String?
  retailPrice   Float // Retail price
  stockQuantity Int      @default(0)
  isFeatured    Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  images     ProductImage[]
  orderItems OrderItem[]
  cartItems  CartItem[]
  reviews    Review[]
  favorites  Favorite[]

  @@map("products")
}

// ─────────────────────────────────────────────
// PRODUCT IMAGE
// ─────────────────────────────────────────────

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  altText   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@map("product_images")
}

// ─────────────────────────────────────────────
// CART
// ─────────────────────────────────────────────

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId]) // One cart item per product per user
  @@map("cart_items")
}

// ─────────────────────────────────────────────
// ORDER
// ─────────────────────────────────────────────

model Order {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  addressId String
  address   Address @relation(fields: [addressId], references: [id])

  status        OrderStatus   @default(PENDING)
  paymentMethod PaymentMethod @default(CASH_ON_DELIVERY)
  paymentStatus PaymentStatus @default(PENDING)

  // Pricing snapshot (stored at time of order)
  subtotal       Float // Before discount
  discountAmount Float @default(0)
  shippingAmount Float @default(0)
  taxAmount      Float @default(0)
  totalAmount    Float // Final amount paid

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items OrderItem[]

  @@map("orders")
}

// ─────────────────────────────────────────────
// ORDER ITEM
// ─────────────────────────────────────────────

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])

  // Snapshot of product at time of order
  productName String
  unitPrice   Float // Price paid per unit (after any discount)
  quantity    Int
  totalPrice  Float // unitPrice * quantity

  createdAt DateTime @default(now())

  @@map("order_items")
}

// ─────────────────────────────────────────────
// REVIEW
// ─────────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  rating    Int // 1–5
  comment   String?
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId]) // One review per product per user
  @@map("reviews")
}

// ─────────────────────────────────────────────
// STORE SETTINGS
// ─────────────────────────────────────────────

model StoreSetting {
  id                    String   @id @default(cuid())
  storeName             String   @default("Center-ElSayad")
  logoUrl               String?
  contactEmail          String?
  contactPhone          String?
  shippingFlatRate      Float    @default(0)
  freeShippingThreshold Float? // Free shipping above this amount
  taxPercent            Float    @default(0)
  updatedAt             DateTime @updatedAt

  @@map("store_settings")
}

// ─────────────────────────────────────────────
// PASSWORD RESET
// ─────────────────────────────────────────────

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String // 6-digit OTP
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("password_resets")
}

// ─────────────────────────────────────────────
// FAVORITE
// ─────────────────────────────────────────────

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@map("favorites")
}
